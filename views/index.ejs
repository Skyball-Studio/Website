  <section class="section" id="projects">
    <div class="container">
      <div class="section-header">
        <span class="monospaced-tag">Our Projects</span>
        <h2 class="section-title">Selected Works</h2>
        <p class="section-desc">Selected game releases demonstrating our focus on atmospheric environments and
          player-driven storylines.</p>
      </div>

      <div class="projects-container">
        <div class="project-item">
          <div class="video-player-wrapper">
            <video class="custom-video"
              poster="/assets/skyball/Skyball/ChatGPT%20Image%20May%2018,%202025,%2001_32_52%20AM.png"
              preload="metadata">
              <source src="/assets/images/forgetful_trailer.web.mp4" type="video/mp4">
            </video>
            <div class="video-overlay-play">
              <div class="play-circle"><i class="fa-solid fa-play"></i></div>
            </div>
          </div>

          <div class="project-info">
            <span class="monospaced-tag">Completed Project</span>
            <h3 class="project-name">Forgetful</h3>
            <p class="project-description">A story-driven 2D platformer set in a dream-like, shifting cosmos. Players
              guide a character who has lost his identity. The game seamlessly embeds narrative in the layout: levels
              repeat familiar paths with subtle, mind-bending changes—platforms disappear, details turn invisible, and
              assets fade away, mirroring the character's deteriorating memory.</p>

            <div class="project-metadata">
              <div class="meta-col">
                <span class="meta-label">Genre</span>
                <span class="meta-value">Story Platformer</span>
              </div>
              <div class="meta-col">
                <span class="meta-label">Art Direction</span>
                <span class="meta-value">Minimal Hand-Painted 2D</span>
              </div>
            </div>

            <div>
              <a href="#contact" class="premium-btn">Connect With Us</a>
            </div>
          </div>
        </div>

        <div class="project-item reverse">
          <div class="project-info">
            <span class="monospaced-tag">Ongoing Project</span>
            <h3 class="project-name">School Buddies</h3>
            <p class="project-description">An episodic 3D third-person social simulator set in a highly responsive
              school campus. The story unfolds in structured chapters as a transfer student navigates tight social
              groups. Conversations, reputations, and dynamics change in real time across labs, classes, and social
              grounds, forcing difficult player choices.</p>

            <div class="project-metadata">
              <div class="meta-col">
                <span class="meta-label">Genre</span>
                <span class="meta-value">Social Simulator / RPG</span>
              </div>
              <div class="meta-col">
                <span class="meta-label">Art Direction</span>
                <span class="meta-value">Stylized 3D, Hand-Painted Textures</span>
              </div>
            </div>

            <div>
              <a href="#contact" class="premium-btn">Start A Project</a>
            </div>
          </div>

          <div class="sb-character-container">
            <div class="sb-character-card">
              <div class="character-card-glow"></div>
              <div class="sb-img-wrapper">
                <img src="/assets/portfolio_stuff/Portfolio%20stuff/max.png" alt="Max Portrait"
                  class="sb-character-img">
              </div>
              <div class="sb-card-details">
                <h4 class="sb-char-name">MAX</h4>
                <span class="sb-char-role">Main Character</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="departments">
    <div class="container">
      <div class="section-header">
        <span class="monospaced-tag">Capabilities</span>
        <h2 class="section-title">Studio Departments</h2>
        <p class="section-desc">Providing full game design services from initial paper concept blueprints to final gold
          master deployment.</p>
      </div>

      <div class="departments-grid">
        <div class="dept-card">
          <div class="dept-icon"><i class="fa-solid fa-paintbrush"></i></div>
          <h3 class="dept-title">2D Concept</h3>
          <p class="dept-desc">Developing early visual foundations, character drafts, layout storyboards, and
            environment concept references to lock in visual style guides.</p>
        </div>

        <div class="dept-card">
          <div class="dept-icon"><i class="fa-solid fa-cube"></i></div>
          <h3 class="dept-title">3D Modeling</h3>
          <p class="dept-desc">Translating visual art into fully optimized, high-fidelity 3D assets, meshes, maps,
            props, and dynamic characters ready for engine integration.</p>
        </div>

        <div class="dept-card">
          <div class="dept-icon"><i class="fa-solid fa-map"></i></div>
          <h3 class="dept-title">Level Design</h3>
          <p class="dept-desc">Crafting detailed maps, progressive player paths, and environmental hazards. Balances
            efficient modular grids with custom showcase visual landmarks.</p>
        </div>

        <div class="dept-card">
          <div class="dept-icon"><i class="fa-solid fa-gamepad"></i></div>
          <h3 class="dept-title">Systems Design</h3>
          <p class="dept-desc">Structuring the fundamental math behind interaction loops, combat equations, branching
            conversations, UI layouts, and core mechanic controllers.</p>
        </div>

        <div class="dept-card">
          <div class="dept-icon"><i class="fa-solid fa-music"></i></div>
          <h3 class="dept-title">Sound Design</h3>
          <p class="dept-desc">Composing deep ambient atmospheric tracks, localized spatial sound effects, voice
            overlays, and acoustic triggers to fully envelop the player.</p>
        </div>

        <div class="dept-card">
          <div class="dept-icon"><i class="fa-solid fa-file-pen"></i></div>
          <h3 class="dept-title">Narrative</h3>
          <p class="dept-desc">Drafting extensive lore bibles, script dialogue sheets, NPC conversation trees,
            environmental journals, and localized game text scripts.</p>
        </div>
      </div>
    </div>
  </section>

